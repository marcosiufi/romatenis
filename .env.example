# ── Domínio (usado pelo Caddy e N8N) ─────────────────────────────────────────
DOMAIN=seusite.com.br

# ── Banco de dados ────────────────────────────────────────────────────────────
DB_NAME=ranking_tenis
DB_USER=ranking
DB_PASSWORD=troque-por-senha-segura

# Em produção, "db" é o nome do serviço Docker (não localhost)
DATABASE_URL=postgresql+asyncpg://ranking:troque-por-senha-segura@db:5432/ranking_tenis

# ── Aplicação ─────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-por-chave-aleatoria-segura

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Asaas (pagamentos) ────────────────────────────────────────────────────────
# Produção: https://api.asaas.com/v3  |  Sandbox: https://sandbox.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=

# ── E-mail (SMTP) ─────────────────────────────────────────────────────────────
# Google Workspace / Gmail: use uma Senha de App (16 caracteres, sem espaços),
# gerada em https://myaccount.google.com/apppasswords com a verificação em duas
# etapas ativa. A senha normal da conta NÃO funciona.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contato@seusite.com.br
SMTP_PASS=
# Nome exibido no remetente
SMTP_FROM_NAME=Roma Tênis
# Deixe vazio para enviar como o próprio SMTP_USER (caso do Google Workspace).
# Só preencha se autenticar com uma conta e enviar em nome de outro endereço —
# o provedor precisa autorizar esse alias, senão rejeita ou cai em spam.
SMTP_FROM=

# ── WhatsApp Business (Meta) ──────────────────────────────────────────────────
# Obtenha em: Meta for Developers → WhatsApp → API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── N8N (orquestrador de mensagens) ──────────────────────────────────────────
N8N_EVENTS_WEBHOOK_URL=https://n8n.seusite.com.br/webhook/ranking-tenis
N8N_SECRET=troque-por-segredo-compartilhado
